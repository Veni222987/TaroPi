{
  "externalWriteConfirm": true,
  "deny": [
    "**/.bashrc",
    "**/.zshrc",
    "**/.bash_profile",
    "**/.bash_history",
    "**/.zsh_history",
    "**/.ssh/**",
    "**/.aws/**",
    "**/.env",
    "**/.env.*",
    {
      "tool": [
        "write",
        "edit"
      ],
      "pattern": ".git/**"
    },
    {
      "tool": "bash",
      "pattern": "rm *",
      "reason": "禁止使用 rm 删除文件。请将文件移动到当前工作目录的 .trash 文件夹下（mkdir -p .trash && mv <target> .trash/）。"
    }
  ]
}