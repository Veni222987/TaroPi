{
  "name": "taropi",
  "private": true,
  "description": "个人 pi coding agent 插件集合(Monorepo)",
  "keywords": [
    "pi-package"
  ],
  "workspaces": [
    "taropi-core",
    "taropi-draw"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./taropi-core/index.ts",
      "./taropi-draw/index.ts"
    ],
    "prompts": [
      "./taropi-draw/prompts"
    ],
    "skills": [
      "./taropi-core/plain/skills"
    ]
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "typebox": "1.1.38",
    "typescript": "^7.0.2"
  }
}
